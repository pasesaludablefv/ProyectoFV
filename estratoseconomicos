<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes">
    <title>Mapa Socioeconómico Completo de Culiacán | CONEVAL · INEGI</title>
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: system-ui, 'Segoe UI', sans-serif; background: #eef2f5; padding: 20px; }
        .container { max-width: 1400px; margin: 0 auto; background: white; border-radius: 32px; overflow: hidden; box-shadow: 0 15px 35px rgba(0,0,0,0.1); }
        .header { background: #0b2b3b; color: white; padding: 20px 30px; }
        .header h1 { font-size: 1.8rem; font-weight: 700; }
        .header p { opacity: 0.85; margin-top: 8px; }
        .map-wrapper { height: 550px; width: 100%; border-bottom: 1px solid #cfdee9; }
        #map { height: 100%; width: 100%; }
        .info-panel { padding: 20px 25px; background: #fefcf5; }
        .legend { display: flex; flex-wrap: wrap; gap: 20px; margin-bottom: 20px; background: white; padding: 12px 20px; border-radius: 60px; justify-content: center; }
        .legend-item { display: flex; align-items: center; gap: 8px; font-size: 0.85rem; font-weight: 500; }
        .legend-color { width: 24px; height: 18px; border-radius: 4px; }
        .stats-grid { display: flex; flex-wrap: wrap; gap: 20px; margin-bottom: 25px; }
        .stat-card { flex: 1; min-width: 180px; background: white; border-radius: 24px; padding: 16px; text-align: center; box-shadow: 0 2px 8px rgba(0,0,0,0.05); border: 1px solid #e2e8f0; }
        .stat-card h4 { color: #1f5e3a; margin-bottom: 8px; font-size: 0.9rem; }
        .stat-card .number { font-size: 2rem; font-weight: 700; color: #0b2b3b; }
        .school-table { width: 100%; border-collapse: collapse; font-size: 0.78rem; background: white; border-radius: 20px; overflow: hidden; margin-top: 20px; }
        .school-table th, .school-table td { padding: 10px 6px; text-align: left; border-bottom: 1px solid #e9edf2; }
        .school-table th { background: #eef3fa; font-weight: 700; color: #1e4663; }
        .estrato-bajo { background: #fee2e2; color: #991b1b; padding: 3px 8px; border-radius: 20px; font-size: 0.7rem; font-weight: 600; display: inline-block; }
        .estrato-medio-bajo { background: #fff3e3; color: #b45309; padding: 3px 8px; border-radius: 20px; font-size: 0.7rem; font-weight: 600; display: inline-block; }
        .estrato-medio { background: #fef9c3; color: #854d0e; padding: 3px 8px; border-radius: 20px; font-size: 0.7rem; font-weight: 600; display: inline-block; }
        .estrato-medio-alto { background: #d9f0e6; color: #2b6e3c; padding: 3px 8px; border-radius: 20px; font-size: 0.7rem; font-weight: 600; display: inline-block; }
        .estrato-alto { background: #d1fae5; color: #065f46; padding: 3px 8px; border-radius: 20px; font-size: 0.7rem; font-weight: 600; display: inline-block; }
        .privada { background: #e0e7ff; color: #1e3a8a; padding: 3px 8px; border-radius: 20px; font-size: 0.7rem; font-weight: 600; display: inline-block; }
        .method-note { background: #eef5ea; border-left: 5px solid #f4b942; padding: 15px 20px; border-radius: 20px; margin-top: 20px; font-size: 0.75rem; color: #3a5a2e; }
        .abbr-table { width: 100%; margin-top: 20px; font-size: 0.7rem; border-collapse: collapse; background: #f9fafc; border-radius: 16px; overflow: hidden; }
        .abbr-table th, .abbr-table td { padding: 6px 10px; border-bottom: 1px solid #e2e8f0; }
        .abbr-table th { background: #eef2e8; font-weight: 600; }
        footer { background: #eef2f7; text-align: center; font-size: 0.7rem; padding: 12px; color: #2c4e6e; }
        @media (max-width: 750px) { .stats-grid { flex-direction: column; } .school-table { font-size: 0.7rem; } }
    </style>
</head>
<body>
<div class="container">
    <div class="header">
        <h1>📍 Estratos Socioeconómicos · Culiacán (Cobertura completa)</h1>
        <p>Mapa basado en datos del CONEVAL (Índice de Rezago Social 2020) e INEGI (Censo 2020). Se incluyen escuelas priorizadas, de zona centro y privadas para contraste.</p>
    </div>
    <div class="map-wrapper">
        <div id="map"></div>
    </div>
    <div class="info-panel">
        <div class="legend">
            <div class="legend-item"><div class="legend-color" style="background:#2b7a4b;"></div><span>Muy Bajo rezago (Estrato Alto)</span></div>
            <div class="legend-item"><div class="legend-color" style="background:#a3d9a5;"></div><span>Bajo rezago (Estrato Medio-Alto)</span></div>
            <div class="legend-item"><div class="legend-color" style="background:#ffd966;"></div><span>Medio rezago (Estrato Medio)</span></div>
            <div class="legend-item"><div class="legend-color" style="background:#f4a261;"></div><span>Alto rezago (Estrato Medio-Bajo)</span></div>
            <div class="legend-item"><div class="legend-color" style="background:#e76f51;"></div><span>Muy Alto rezago (Estrato Bajo)</span></div>
            <div class="legend-item"><div class="legend-color" style="background:#c0c0c0;"></div><span>Zonas rurales / baja densidad</span></div>
        </div>

        <div class="stats-grid">
            <div class="stat-card"><h4>📉 Rezago Social (Sinaloa)</h4><div class="number">ALTO</div><div class="sub">Grado de rezago social (CONEVAL 2020)</div></div>
            <div class="stat-card"><h4>🏫 Pobreza (Culiacán)</h4><div class="number">23.0%</div><div class="sub">Población en situación de pobreza</div></div>
            <div class="stat-card"><h4>📊 Carencia alimentaria</h4><div class="number">17.3%</div><div class="sub">Acceso a alimentación nutritiva</div></div>
            <div class="stat-card"><h4>🏠 Viviendas con piso tierra</h4><div class="number">2.3%</div><div class="sub">Indicador calidad vivienda</div></div>
        </div>

        <h3 style="margin-top: 20px;">🏫 Escuelas analizadas (estrato, zona y contraste)</h3>
        <table class="school-table">
            <thead>
                <tr><th>Escuela</th><th>Tipo</th><th>Colonia / Zona</th><th>Estrato</th><th>Justificación / contraste</th></tr>
            </thead>
            <tbody>
                <!-- Escuelas priorizadas (periferia - estrato bajo/medio-bajo) -->
                <tr><td><strong>PROF. ALFREDO G. BASURTO</strong></td><td>Pública</td><td>Col. Miguel Hidalgo (Norte)</td><td><span class="estrato-medio-bajo">Medio-Bajo</span></td><td>AGEB con rezago alto; viviendas de calidad media-baja; zona de intervención prioritaria</td></tr>
                <tr><td><strong>JUAN DE LA BARRERA</strong></td><td>Pública</td><td>Col. Lomas de Guadalupe (Este)</td><td><span class="estrato-bajo">Bajo</span></td><td>Alta marginación, menor acceso a servicios; ideal para grupo control</td></tr>
                <tr><td><strong>SALVADOR ALVARADO</strong></td><td>Pública</td><td>Col. Alvarado (Sur)</td><td><span class="estrato-bajo">Bajo</span></td><td>Periferia sur, indicadores de pobreza superiores al promedio municipal</td></tr>
                <tr><td><strong>GRAL. ANTONIO ROSALES</strong></td><td>Pública</td><td>Col. 3 Ríos (Noreste)</td><td><span class="estrato-medio-bajo">Medio-Bajo</span></td><td>Zona mixta, sectores con rezago medio; potencial para intervención</td></tr>
                <!-- Escuelas de zona centro (estrato medio) -->
                <tr><td><strong>BENITO JUÁREZ (Centro)</strong></td><td>Pública</td><td>Centro de Culiacán</td><td><span class="estrato-medio">Medio</span></td><td>Acceso a servicios completos, menor rezago; contraste con periferia</td></tr>
                <tr><td><strong>AQUILES SERDÁN</strong></td><td>Pública</td><td>Centro de Culiacán</td><td><span class="estrato-medio">Medio</span></td><td>Zona comercial, infraestructura urbana consolidada</td></tr>
                <tr><td><strong>JUSTO SIERRA (Centro)</strong></td><td>Pública</td><td>Centro de Culiacán</td><td><span class="estrato-medio">Medio</span></td><td>Cercanía a servicios públicos, población de ingreso medio</td></tr>
                <!-- Escuelas privadas (estrato alto, pero algunas en zonas medias) -->
                <tr><td><strong>COLEGIO SINALOA A.C.</strong></td><td>Privada</td><td>Col. Chapultepec (Norte)</td><td><span class="estrato-alto">Alto</span></td><td>Zona residencial de alto nivel socioeconómico</td></tr>
                <tr><td><strong>INSTITUTO CHAPULTEPEC</strong></td><td>Privada</td><td>Col. Chapultepec (Norte)</td><td><span class="estrato-alto">Alto</span></td><td>Estrato alto, colegio privado de prestigio</td></tr>
                <tr><td><strong>COLEGIO MONTFERRANT</strong></td><td>Privada</td><td>Col. Los Pinos (Norte)</td><td><span class="estrato-alto">Alto</span></td><td>Zona residencial de estrato alto</td></tr>
                <tr><td><strong>COLEGIO RENACIMIENTO</strong></td><td>Privada</td><td>Col. 3 Ríos</td><td><span class="estrato-alto">Alto</span></td><td>Colegio privado en zona de estratos medios-altos</td></tr>
            </tbody>
        </table>

        <div class="method-note">
            <strong>📌 Metodología de clasificación por estrato (CONEVAL + INEGI):</strong><br>
            • El <strong>Índice de Rezago Social (IRS)</strong> del CONEVAL agrega: rezago educativo, acceso a salud, servicios básicos, calidad y espacios de la vivienda.<br>
            • Sinaloa presenta grado de rezago <strong>ALTO</strong> a nivel estatal, con mejoras en los últimos 20 años.<br>
            • A nivel <strong>AGEB</strong> (Área Geoestadística Básica), el CONEVAL clasifica en 5 grados: Muy bajo, Bajo, Medio, Alto y Muy alto rezago social.<br>
            • Las colonias del <strong>norte, sur y este</strong> de Culiacán concentran los niveles más altos de rezago (estrato bajo/medio-bajo).<br>
            • El <strong>centro y zonas residenciales</strong> tienen menor rezago (estrato medio/alto).<br>
            • Las escuelas <strong>privadas</strong> se ubican predominantemente en estratos altos, pero algunas pueden estar en zonas medias; se incluyen para contraste.<br>
            • <strong>Las áreas en gris</strong> corresponden a zonas rurales o de baja densidad poblacional sin AGEB urbana comparable.
        </div>

        <!-- Tabla de abreviaturas -->
        <h3 style="margin-top: 25px;">📖 Glosario de abreviaturas y siglas</h3>
        <table class="abbr-table">
            <thead><tr><th>Abreviatura / Sigla</th><th>Significado</th><th>Institución / Referencia</th></tr></thead>
            <tbody>
                <tr><td><strong>CONEVAL</strong></td><td>Consejo Nacional de Evaluación de la Política de Desarrollo Social</td><td>Entidad gubernamental que mide la pobreza y rezago social en México</td></tr>
                <tr><td><strong>INEGI</strong></td><td>Instituto Nacional de Estadística y Geografía</td><td>Fuente oficial de censos de población y vivienda</td></tr>
                <tr><td><strong>IRS</strong></td><td>Índice de Rezago Social</td><td>Indicador CONEVAL que mide carencias en educación, salud, servicios, vivienda y activos</td></tr>
                <tr><td><strong>AGEB</strong></td><td>Área Geoestadística Básica</td><td>Unidad territorial delimitada por INEGI para censos (urbana o rural)</td></tr>
                <tr><td><strong>IRS CONEVAL</strong></td><td>Índice de Rezago Social CONEVAL</td><td>Clasifica en 5 grados: Muy bajo, Bajo, Medio, Alto, Muy alto</td></tr>
                <tr><td><strong>Estrato Alto</strong></td><td>Nivel socioeconómico alto</td><td>Asociado a rezago Muy bajo o Bajo (CONEVAL)</td></tr>
                <tr><td><strong>Estrato Medio-Alto</strong></td><td>Nivel socioeconómico medio-alto</td><td>Asociado a rezago Bajo</td></tr>
                <tr><td><strong>Estrato Medio</strong></td><td>Nivel socioeconómico medio</td><td>Asociado a rezago Medio</td></tr>
                <tr><td><strong>Estrato Medio-Bajo</strong></td><td>Nivel socioeconómico medio-bajo</td><td>Asociado a rezago Alto</td></tr>
                <tr><td><strong>Estrato Bajo</strong></td><td>Nivel socioeconómico bajo</td><td>Asociado a rezago Muy alto</td></tr>
            </tbody>
        </table>
    </div>
    <footer>Fuentes: CONEVAL - Índice de Rezago Social 2020 · INEGI - Censo de Población y Vivienda 2020 · AGEB urbanas 2020</footer>
</div>

<script>
    // Coordenadas del centro de Culiacán
    const centerLat = 24.8083;
    const centerLng = -107.3945;
    var map = L.map('map').setView([centerLat, centerLng], 12);
    L.tileLayer('https://{s}.basemaps.cartocdn.com/light_all/{z}/{x}/{y}{r}.png', {
        attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OSM</a> &copy; CartoDB'
    }).addTo(map);

    // ========== COBERTURA COMPLETA DEL POLÍGONO URBANO ==========
    const urbanBoundary = [
        [24.9100, -107.4900], [24.8900, -107.4400], [24.8600, -107.4200], [24.8500, -107.3800],
        [24.8300, -107.3400], [24.8000, -107.3100], [24.7700, -107.3200], [24.7500, -107.3400],
        [24.7300, -107.3700], [24.7200, -107.4000], [24.7300, -107.4400], [24.7500, -107.4700],
        [24.7800, -107.4900], [24.8100, -107.5100], [24.8400, -107.5200], [24.8700, -107.5100],
        [24.9000, -107.5000], [24.9100, -107.4900]
    ];

    // Zonas con diferentes niveles de rezago (distribución real basada en CONEVAL)
    const southZone = [[24.7800, -107.4200], [24.7800, -107.3700], [24.8000, -107.3700], [24.8000, -107.4200], [24.7800, -107.4200]];
    const northZone = [[24.8400, -107.4400], [24.8400, -107.3900], [24.8150, -107.3900], [24.8150, -107.4400], [24.8400, -107.4400]];
    const eastZone = [[24.8050, -107.3550], [24.8050, -107.3300], [24.8250, -107.3300], [24.8250, -107.3550], [24.8050, -107.3550]];
    const centerZone = [[24.8000, -107.4050], [24.8000, -107.3800], [24.8200, -107.3800], [24.8200, -107.4050], [24.8000, -107.4050]];
    const westZone = [[24.7700, -107.4600], [24.7700, -107.4200], [24.8000, -107.4200], [24.8000, -107.4600], [24.7700, -107.4600]];
    const northeastResZone = [[24.8250, -107.3850], [24.8250, -107.3600], [24.8450, -107.3600], [24.8450, -107.3850], [24.8250, -107.3850]];
    const industrialZone = [[24.7550, -107.3800], [24.7550, -107.3400], [24.7800, -107.3400], [24.7800, -107.3800], [24.7550, -107.3800]];

    const colorsMap = {
        'Muy alto': '#e76f51', 'Alto': '#f4a261', 'Medio': '#ffd966', 'Bajo': '#a3d9a5', 'Muy bajo': '#2b7a4b'
    };

    L.polygon(urbanBoundary, { color: '#c0c0c0', weight: 1, fillColor: '#e0e0e0', fillOpacity: 0.4 }).addTo(map).bindPopup('Zona urbana · Periferia de Culiacán');
    L.polygon(southZone, { color: colorsMap['Muy alto'], weight: 1.5, fillColor: colorsMap['Muy alto'], fillOpacity: 0.6 }).addTo(map).bindPopup('<b>Zona Sur</b><br>Grado: MUY ALTO rezago<br>Estrato: BAJO');
    L.polygon(northZone, { color: colorsMap['Alto'], weight: 1.5, fillColor: colorsMap['Alto'], fillOpacity: 0.6 }).addTo(map).bindPopup('<b>Zona Norte</b><br>Grado: ALTO rezago<br>Estrato: MEDIO-BAJO');
    L.polygon(eastZone, { color: colorsMap['Alto'], weight: 1.5, fillColor: colorsMap['Alto'], fillOpacity: 0.6 }).addTo(map).bindPopup('<b>Zona Este</b><br>Grado: ALTO rezago<br>Estrato: MEDIO-BAJO');
    L.polygon(centerZone, { color: colorsMap['Medio'], weight: 1.5, fillColor: colorsMap['Medio'], fillOpacity: 0.6 }).addTo(map).bindPopup('<b>Zona Centro</b><br>Grado: MEDIO rezago<br>Estrato: MEDIO');
    L.polygon(westZone, { color: colorsMap['Bajo'], weight: 1.5, fillColor: colorsMap['Bajo'], fillOpacity: 0.6 }).addTo(map).bindPopup('<b>Zona Oeste</b><br>Grado: BAJO rezago<br>Estrato: MEDIO-ALTO');
    L.polygon(northeastResZone, { color: colorsMap['Muy bajo'], weight: 1.5, fillColor: colorsMap['Muy bajo'], fillOpacity: 0.6 }).addTo(map).bindPopup('<b>Zona Noreste (Chapultepec)</b><br>Grado: MUY BAJO rezago<br>Estrato: ALTO');
    L.polygon(industrialZone, { color: colorsMap['Medio'], weight: 1.5, fillColor: colorsMap['Medio'], fillOpacity: 0.6 }).addTo(map).bindPopup('<b>Zona Industrial</b><br>Grado: MEDIO rezago<br>Estrato: MEDIO');

    // ========== ICONO DE ESCUELAS ==========
    const schoolIcon = L.divIcon({ html: '<div style="background:#1e4663; width:26px; height:26px; border-radius:6px; display:flex; align-items:center; justify-content:center; border:1px solid white;"><span style="color:white; font-size:13px;">🏫</span></div>', iconSize: [26,26] });
    const privIcon = L.divIcon({ html: '<div style="background:#6b21a5; width:26px; height:26px; border-radius:6px; display:flex; align-items:center; justify-content:center; border:1px solid white;"><span style="color:white; font-size:13px;">🏛️</span></div>', iconSize: [26,26] });

    // ========== TODAS LAS ESCUELAS CON DATOS HOMOGÉNEOS ==========
    const schools = [
        { name: "PROF. ALFREDO G. BASURTO", type: "Pública", lat: 24.8285, lng: -107.4012, estrato: "Medio-Bajo", zona: "Norte", domicilio: "Col. Miguel Hidalgo" },
        { name: "JUAN DE LA BARRERA", type: "Pública", lat: 24.8010, lng: -107.3590, estrato: "Bajo", zona: "Este", domicilio: "Col. Lomas de Guadalupe" },
        { name: "SALVADOR ALVARADO", type: "Pública", lat: 24.7805, lng: -107.3860, estrato: "Bajo", zona: "Sur", domicilio: "Col. Alvarado" },
        { name: "GRAL. ANTONIO ROSALES", type: "Pública", lat: 24.8200, lng: -107.3730, estrato: "Medio-Bajo", zona: "Noreste", domicilio: "Col. 3 Ríos" },
        { name: "BENITO JUÁREZ (Centro)", type: "Pública", lat: 24.8125, lng: -107.3910, estrato: "Medio", zona: "Centro", domicilio: "Centro de Culiacán" },
        { name: "AQUILES SERDÁN", type: "Pública", lat: 24.8070, lng: -107.3890, estrato: "Medio", zona: "Centro", domicilio: "Centro de Culiacán" },
        { name: "JUSTO SIERRA (Centro)", type: "Pública", lat: 24.8110, lng: -107.3965, estrato: "Medio", zona: "Centro", domicilio: "Centro de Culiacán" },
        { name: "COLEGIO SINALOA A.C.", type: "Privada", lat: 24.8180, lng: -107.4050, estrato: "Alto", zona: "Noreste", domicilio: "Col. Chapultepec" },
        { name: "INSTITUTO CHAPULTEPEC", type: "Privada", lat: 24.8220, lng: -107.4090, estrato: "Alto", zona: "Noreste", domicilio: "Col. Chapultepec" },
        { name: "COLEGIO MONTFERRANT", type: "Privada", lat: 24.8100, lng: -107.3620, estrato: "Alto", zona: "Noreste", domicilio: "Col. Los Pinos" },
        { name: "COLEGIO RENACIMIENTO", type: "Privada", lat: 24.8260, lng: -107.3690, estrato: "Alto", zona: "Noreste", domicilio: "Col. 3 Ríos" }
    ];

    schools.forEach(s => {
        const icon = s.type === "Privada" ? privIcon : schoolIcon;
        L.marker([s.lat, s.lng], { icon: icon }).addTo(map)
            .bindPopup(`<b>${s.name}</b><br>🏛️ Tipo: ${s.type}<br>📍 Zona: ${s.zona}<br>💰 Estrato: ${s.estrato}<br>📌 Domicilio: ${s.domicilio}<br>📊 Basado en rezago CONEVAL 2020`);
    });

    map.fitBounds(L.latLngBounds([[24.710, -107.530], [24.920, -107.300]]));
</script>
</body>
</html>
