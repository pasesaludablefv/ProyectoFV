<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Anexo metodológico · Top 50 escuelas</title>
<style>
:root {
  --uas-blue:#003B70;
  --uas-light:#005B96;
  --uas-gold:#D4A017;
  --bg:#f5f7fa;
  --text:#263238;
  --green:#2E7D32;
  --blue:#2563eb;
  --orange:#EF6C00;
  --red:#C62828;
  --shadow:0 6px 18px rgba(0,0,0,.12);
}
*{box-sizing:border-box}
body{
  margin:0;
  font-family:Segoe UI,Arial,sans-serif;
  background:var(--bg);
  color:var(--text);
  line-height:1.55;
}
.hero{
  background:linear-gradient(135deg,var(--uas-blue),var(--uas-light));
  color:white;
  text-align:center;
  padding:38px 20px;
}
.hero h1{margin:0 0 10px;font-size:2rem}
.hero p{margin:0;opacity:.92}
.container{width:96%;max-width:1650px;margin:0 auto}
.section{margin:30px auto}
.section-title{
  color:var(--uas-blue);
  border-left:6px solid var(--uas-gold);
  padding-left:12px;
  margin-bottom:18px;
  font-size:1.35rem;
}
.cards{
  display:grid;
  grid-template-columns:repeat(auto-fit,minmax(210px,1fr));
  gap:16px;
}
.card{
  background:#fff;
  padding:20px;
  border-radius:16px;
  text-align:center;
  box-shadow:var(--shadow);
}
.card h3{margin:0;color:var(--uas-blue);font-size:.95rem}
.card .num{font-size:2.35rem;font-weight:800;color:var(--uas-blue)}
.notice{
  background:#FFF8E1;
  border-left:6px solid var(--uas-gold);
  padding:18px;
  border-radius:14px;
  margin-top:14px;
}
.toolbar{
  display:flex;
  flex-wrap:wrap;
  gap:10px;
  align-items:center;
  margin-bottom:14px;
}
input, select{
  padding:10px 12px;
  border:1px solid #cbd5e1;
  border-radius:10px;
  background:#fff;
  font-size:.9rem;
}
.table-wrapper{
  overflow-x:auto;
  background:#fff;
  border-radius:16px;
  box-shadow:var(--shadow);
}
table{
  width:100%;
  border-collapse:collapse;
  min-width:1450px;
  font-size:.82rem;
}
thead{
  background:var(--uas-blue);
  color:#fff;
  position:sticky;
  top:0;
  z-index:2;
}
th,td{
  padding:9px 8px;
  border-bottom:1px solid #e5e7eb;
  text-align:center;
  vertical-align:middle;
}
tbody tr:hover{background:#f8fafc}
.school{text-align:left;min-width:245px}
.badge,.prio{
  display:inline-block;
  padding:4px 8px;
  border-radius:999px;
  font-size:.72rem;
  font-weight:700;
  color:#fff;
  white-space:nowrap;
}
.badge.top10{background:var(--uas-gold);color:#1f2937}
.badge.culiacan{background:var(--green)}
.badge.fuera{background:#64748b}
.prio.muy{background:var(--green)}
.prio.alta{background:var(--blue)}
.prio.media{background:var(--orange)}
.prio.baja{background:var(--red)}
.method{
  background:#fff;
  border-radius:16px;
  box-shadow:var(--shadow);
  padding:22px;
}
.method ul{margin:0 0 0 20px}
footer{
  background:var(--uas-blue);
  color:white;
  text-align:center;
  padding:18px;
  margin-top:36px;
  font-size:.88rem;
}
@media print {
  .toolbar{display:none}
  body{background:white}
  .table-wrapper{box-shadow:none}
  .hero{padding:20px}
}
</style>
</head>
