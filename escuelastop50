<script>
function normalizeText(txt){
  return (txt || "").toString().toLowerCase().normalize("NFD").replace(/[\u0300-\u036f]/g, "");
}

function filterTable(){
  const search = normalizeText(document.getElementById("searchBox").value);
  const classFilter = document.getElementById("classFilter").value;
  const top10Filter = document.getElementById("top10Filter").value;
  const rows = document.querySelectorAll("#top50Table tbody tr");

  rows.forEach(row => {
    const text = normalizeText(row.innerText);
    const clasif = row.getAttribute("data-clasificacion");
    const top10 = row.getAttribute("data-top10");

    const okSearch = !search || text.includes(search);
    const okClass = !classFilter || clasif === classFilter;
    const okTop10 = !top10Filter || top10 === top10Filter;

    row.style.display = (okSearch && okClass && okTop10) ? "" : "none";
  });
}
</script>

